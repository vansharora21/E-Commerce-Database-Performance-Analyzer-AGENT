# ============================================================
# AGENTIC AI SALES & DB INSIGHT SYSTEM — Environment Config
# ============================================================
# Copy this file to .env and fill in your values

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/fashion_ecommerce
DB_NAME=fashion_ecommerce

# ── Google Gemini API ────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── Security ─────────────────────────────────────────────────
# Header: X-Admin-Key: <value below>
ADMIN_API_KEY=change-this-to-a-strong-random-secret

# ── Agent Tuning ─────────────────────────────────────────────
AGENT_MAX_RETRIES=3
AGENT_TEMPERATURE=0.1
